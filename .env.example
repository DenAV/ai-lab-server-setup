# AI Lab Server Setup — Environment Variables
#
# Auto-generate with all secrets:
#   bash scripts/generate-env.sh example.com user@example.com
#
# Or copy and edit manually:
#   cp .env.example .env && nano .env
#
# NEVER commit .env — only .env.example

# =============================================================================
# General
# =============================================================================
DOMAIN=example.com
ACME_EMAIL=user@example.com
TIMEZONE=Europe/Berlin

# =============================================================================
# Flowise
# =============================================================================
FLOWISE_VERSION=latest
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=CHANGE-ME-flowise-password
FLOWISE_SECRETKEY_OVERWRITE=CHANGE-ME-flowise-secret

# =============================================================================
# n8n
# =============================================================================
N8N_VERSION=latest
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE-ME-n8n-password
N8N_ENCRYPTION_KEY=CHANGE-ME-n8n-encryption-key

# =============================================================================
# Ollama
# =============================================================================
OLLAMA_VERSION=latest

# =============================================================================
# Qdrant
# =============================================================================
QDRANT_VERSION=latest
QDRANT_API_KEY=CHANGE-ME-qdrant-api-key

# =============================================================================
# Langfuse
# =============================================================================
LANGFUSE_VERSION=2
LANGFUSE_SECRET_KEY=CHANGE-ME-langfuse-secret
LANGFUSE_NEXT_AUTH_SECRET=CHANGE-ME-langfuse-auth-secret
LANGFUSE_SALT=CHANGE-ME-langfuse-salt
LANGFUSE_DB_PASSWORD=CHANGE-ME-langfuse-db-password

# =============================================================================
# Traefik
# =============================================================================
TRAEFIK_VERSION=v3.3

# =============================================================================
# Dify
# =============================================================================
DIFY_VERSION=1.13.3
DIFY_SECRET_KEY=CHANGE-ME-dify-secret-key
DIFY_DB_PASSWORD=CHANGE-ME-dify-db-password
DIFY_REDIS_PASSWORD=CHANGE-ME-dify-redis-password
DIFY_SANDBOX_KEY=CHANGE-ME-dify-sandbox-key
DIFY_SANDBOX_VERSION=0.2.14
DIFY_PLUGIN_VERSION=0.5.3-local
DIFY_PLUGIN_DAEMON_KEY=CHANGE-ME-dify-plugin-daemon-key
DIFY_PLUGIN_INNER_API_KEY=CHANGE-ME-dify-plugin-inner-api-key
